---
import Layout from '../../layouts/Layout.astro';
import ThemeDemo from '../../components/ThemeDemo.svelte';
import { meta } from '../../lib/components/theme-switcher/schema';
---

<Layout title="Theme — GlassUI">
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold text-white">Theme</h1>
      <p class="text-white/60 mt-2">5 color presets and dark/light mode. Components respond to theme changes via CSS custom properties.</p>
      <pre class="mt-3 text-sm text-cyan-300 bg-black/30 rounded-xl px-4 py-2 inline-block"><code>{meta.import}</code></pre>
    </div>
    <ThemeDemo client:load />
  </div>
</Layout>
