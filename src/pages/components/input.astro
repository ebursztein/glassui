---
import Layout from '../../layouts/Layout.astro';
import InputDemo from '../../components/InputDemo.svelte';
---

<Layout title="Input - GlassUI">
  <div class="space-y-6">
    <div>
      <p class="text-sm font-medium text-primary mb-1">Components</p>
      <h1 class="text-3xl font-bold text-foreground tracking-tight">Input</h1>
      <p class="mt-2 text-muted-foreground-2">
        Text input with size variants, status colors, label, helper text, error messages, and optional glass surface with glow on focus.
      </p>
    </div>

    <hr class="border-border" />

    <InputDemo client:load />
  </div>
</Layout>
