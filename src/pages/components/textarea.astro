---
import Layout from '../../layouts/Layout.astro';
import TextareaDemo from '../../components/TextareaDemo.svelte';
---

<Layout title="Textarea - GlassUI">
  <div class="space-y-6">
    <div>
      <p class="text-sm font-medium text-primary mb-1">Components</p>
      <h1 class="text-3xl font-bold text-foreground tracking-tight">Textarea</h1>
      <p class="mt-2 text-muted-foreground-2">
        Multi-line text input with size variants, status colors, label, helper text, error messages, and optional glass surface with glow on focus.
      </p>
    </div>

    <hr class="border-border" />

    <TextareaDemo client:load />
  </div>
</Layout>
