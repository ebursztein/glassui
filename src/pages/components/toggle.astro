---
import Layout from '../../layouts/Layout.astro';
import ToggleDemo from '../../components/ToggleDemo.svelte';
import { meta } from '../../lib/components/toggle/schema';
---

<Layout title={`${meta.name} — GlassUI`}>
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold text-white">{meta.name}</h1>
      <p class="text-white/60 mt-2">{meta.description}</p>
      <pre class="mt-3 text-sm text-cyan-300 bg-black/30 rounded-xl px-4 py-2 inline-block"><code>{meta.import}</code></pre>
    </div>
    <ToggleDemo client:load />
  </div>
</Layout>
