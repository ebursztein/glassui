---
import Layout from '../../layouts/Layout.astro';
import ToggleDemo from '../../components/ToggleDemo.svelte';
---

<Layout title="Toggle - GlassUI">
  <div class="space-y-6">
    <div>
      <p class="text-sm font-medium text-primary mb-1">Components</p>
      <h1 class="text-3xl font-bold text-foreground tracking-tight">Toggle</h1>
      <p class="mt-2 text-muted-foreground-2">
        Switch toggle with size variants, label support, and optional glass surface. Keyboard accessible.
      </p>
    </div>

    <hr class="border-border" />

    <ToggleDemo client:load />
  </div>
</Layout>
