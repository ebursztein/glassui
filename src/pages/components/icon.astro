---
import Layout from '../../layouts/Layout.astro';
import IconDemo from '../../components/IconDemo.svelte';
---

<Layout title="Icon - GlassUI">
  <div class="space-y-6">
    <div>
      <p class="text-sm font-medium text-primary mb-1">Components</p>
      <h1 class="text-3xl font-bold text-foreground tracking-tight">Icon</h1>
      <p class="mt-2 text-muted-foreground-2">
        Renders icons by name using Phosphor icons. Supports 6 weights, any pixel size, and all Iconify icon sets via prefix.
      </p>
    </div>

    <hr class="border-border" />

    <IconDemo client:load />
  </div>
</Layout>
