---
import Layout from '../../layouts/Layout.astro';
import AlertDemo from '../../components/AlertDemo.svelte';
---

<Layout title="Alert - GlassUI">
  <div class="space-y-6">
    <div>
      <p class="text-sm font-medium text-primary mb-1">Components</p>
      <h1 class="text-3xl font-bold text-foreground tracking-tight">Alert</h1>
      <p class="mt-2 text-muted-foreground-2">
        Status-based alerts with icon, title, body, and optional dismiss. 4 statuses with glass and glow support.
      </p>
    </div>

    <hr class="border-border" />

    <AlertDemo client:load />
  </div>
</Layout>
