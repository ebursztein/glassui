---
import Layout from '../../layouts/Layout.astro';
import CardDemo from '../../components/CardDemo.svelte';
---

<Layout title="Card - GlassUI">
  <div class="space-y-6">
    <div>
      <p class="text-sm font-medium text-primary mb-1">Components</p>
      <h1 class="text-3xl font-bold text-foreground tracking-tight">Card</h1>
      <p class="mt-2 text-muted-foreground-2">
        Composable container with optional glass surface, glow, and hover effects. Build with CardHeader, CardTitle, CardDescription, CardContent, and CardFooter.
      </p>
    </div>

    <hr class="border-border" />

    <CardDemo client:load />
  </div>
</Layout>
