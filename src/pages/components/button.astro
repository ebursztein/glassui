---
import Layout from '../../layouts/Layout.astro';
import ButtonDemo from '../../components/ButtonDemo.svelte';
---

<Layout title="Button - GlassUI">
  <div class="space-y-6">
    <div>
      <p class="text-sm font-medium text-primary mb-1">Components</p>
      <h1 class="text-3xl font-bold text-foreground tracking-tight">Button</h1>
      <p class="mt-2 text-muted-foreground-2">
        Browse and customize buttons in various styles, states, and sizes. 6 variants, 5 sizes, with optional glass surface and glow effects.
      </p>
    </div>

    <hr class="border-border" />

    <ButtonDemo client:load />
  </div>
</Layout>
