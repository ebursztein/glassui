---
import Layout from '../../layouts/Layout.astro';
import BadgeDemo from '../../components/BadgeDemo.svelte';
---

<Layout title="Badge - GlassUI">
  <div class="space-y-6">
    <div>
      <p class="text-sm font-medium text-primary mb-1">Components</p>
      <h1 class="text-3xl font-bold text-foreground tracking-tight">Badge</h1>
      <p class="mt-2 text-muted-foreground-2">
        Inline labels with variant or status colors, dot indicators, and optional glass surface. 6 variants, 5 sizes.
      </p>
    </div>

    <hr class="border-border" />

    <BadgeDemo client:load />
  </div>
</Layout>
