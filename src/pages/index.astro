---
import Layout from '../layouts/Layout.astro';
---

<Layout title="GlassUI — Glass Design System">
  <div class="space-y-12">
    <!-- Hero -->
    <section class="space-y-4">
      <h1 class="text-4xl md:text-5xl font-bold text-white">
        Glass<span class="bg-gradient-to-r from-cyan-400 via-blue-400 to-purple-400 bg-clip-text text-transparent">UI</span>
      </h1>
      <p class="text-lg text-white/60 max-w-2xl">
        A state-of-the-art Svelte 5 component library with glassmorphism design, Zod-driven schemas, and built-in theme system.
      </p>
      <div class="flex gap-3 mt-6">
        <a
          href="/components/button"
          class="inline-flex items-center gap-2 h-10 px-4 rounded-xl bg-gradient-to-r from-cyan-500/80 via-blue-500/80 to-purple-500/80 text-white font-medium text-sm border border-white/30 hover:scale-[1.03] active:scale-[0.97] transition-all duration-200"
        >
          Get started
        </a>
      </div>
    </section>

    <!-- Component grid -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold text-white">Components</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a
          href="/components/icon"
          class="group relative rounded-2xl border border-white/20 bg-white/10 backdrop-blur-xl p-6 shadow-[0_8px_32px_rgba(0,0,0,0.37)] hover:border-white/30 hover:bg-white/15 transition-all duration-300"
        >
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-b from-white/10 to-transparent pointer-events-none"></div>
          <div class="relative z-10">
            <h3 class="text-lg font-semibold text-white">Icon</h3>
            <p class="text-sm text-white/60 mt-1">Phosphor icons with validated size and weight</p>
          </div>
        </a>

        <a
          href="/components/button"
          class="group relative rounded-2xl border border-white/20 bg-white/10 backdrop-blur-xl p-6 shadow-[0_8px_32px_rgba(0,0,0,0.37)] hover:border-white/30 hover:bg-white/15 transition-all duration-300"
        >
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-b from-white/10 to-transparent pointer-events-none"></div>
          <div class="relative z-10">
            <h3 class="text-lg font-semibold text-white">Button</h3>
            <p class="text-sm text-white/60 mt-1">5 variants, 5 sizes, optional glow effect</p>
          </div>
        </a>
      </div>
    </section>

    <!-- Features -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold text-white">Features</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          { title: 'Svelte 5 Runes', desc: '$props, $state, $derived, snippets' },
          { title: 'Zod 4 Schemas', desc: 'Single source of truth for types, MCP, skills' },
          { title: 'Theme System', desc: 'CSS custom properties with named presets' },
          { title: 'Phosphor Icons', desc: 'Adjustable size and weight' },
          { title: 'Global State', desc: 'Theme, notifications, dialogs' },
          { title: 'MCP Server', desc: 'Auto-discovers components for Claude' },
        ].map(({ title, desc }) => (
          <div class="rounded-xl border border-white/10 bg-white/5 backdrop-blur-xl p-4">
            <h3 class="text-sm font-semibold text-white">{title}</h3>
            <p class="text-xs text-white/50 mt-1">{desc}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>
