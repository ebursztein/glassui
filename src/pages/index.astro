---
import Layout from '../layouts/Layout.astro';

const components = [
  { name: 'Button', description: '6 variants, 5 sizes, glass + glow, loading state', href: '/components/button' },
  { name: 'Card', description: 'Composable sub-components, glass surface, hover effects', href: '/components/card' },
  { name: 'Badge', description: 'Variant and status colors, dot indicator, glass', href: '/components/badge' },
  { name: 'Alert', description: '4 status types, dismissible, glass + glow', href: '/components/alert' },
  { name: 'Input', description: 'Sizes, status, label, error/helper text, glass', href: '/components/input' },
  { name: 'Toggle', description: 'Switch with sizes, labels, keyboard accessible', href: '/components/toggle' },
  { name: 'Textarea', description: 'Multi-line input, resize control, status, glass', href: '/components/textarea' },
  { name: 'Icon', description: 'Phosphor icons with size and weight control', href: '/components/icon' },
];
---

<Layout title="GlassUI - Svelte 5 Component Library">
  <div class="max-w-3xl">
    <div class="mb-12">
      <p class="text-sm font-medium text-primary mb-2">Components</p>
      <h1 class="text-4xl font-bold text-foreground tracking-tight">GlassUI Component Library</h1>
      <p class="mt-4 text-lg text-muted-foreground-2">
        A Preline-inspired component library for Svelte 5 + Astro. Clean, accessible components with optional glass and glow effects.
      </p>
      <div class="mt-6 flex gap-3">
        <a href="/components/button" class="inline-flex items-center px-4 py-2.5 text-sm font-medium rounded-lg bg-primary text-primary-foreground hover:bg-primary-hover transition-colors">
          Get started
        </a>
        <a href="/components/theme" class="inline-flex items-center px-4 py-2.5 text-sm font-medium rounded-lg border border-line-2 text-foreground hover:bg-layer-hover transition-colors">
          Theme system
        </a>
      </div>
    </div>

    <hr class="border-border mb-10" />

    <h2 class="text-xl font-semibold text-foreground mb-6">Components</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {components.map((c) => (
        <a href={c.href} class="group block p-5 rounded-lg border border-border hover:border-primary/40 hover:shadow-sm transition-all">
          <h3 class="font-semibold text-foreground group-hover:text-primary transition-colors">{c.name}</h3>
          <p class="mt-1 text-sm text-muted-foreground">{c.description}</p>
        </a>
      ))}
    </div>
  </div>
</Layout>
