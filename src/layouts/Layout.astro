---
import '../styles/globals.css';
import { Background } from '$lib/components/background';
import { BackgroundSwitcher } from '$lib/components/background';
import { ThemeSwitcher } from '$lib/components/theme-switcher';
import { Sidebar, SidebarHeader, SidebarSection, SidebarItem, SidebarFooter } from '$lib/components/sidebar';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'GlassUI', description = 'Glass design system -- Svelte 5 component library' } = Astro.props;
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen antialiased">
    <Background client:load />

    <div class="relative flex min-h-screen">
      <Sidebar client:load>
        <SidebarHeader>
          <span class="w-8 h-8 rounded-lg bg-gradient-to-r from-cyan-500 via-blue-500 to-purple-500 flex items-center justify-center text-sm font-bold">G</span>
          GlassUI
        </SidebarHeader>

        <SidebarSection label="Components">
          <SidebarItem href="/components/icon" active={path.startsWith('/components/icon')}>Icon</SidebarItem>
          <SidebarItem href="/components/button" active={path.startsWith('/components/button')}>Button</SidebarItem>
          <SidebarItem href="/components/card" active={path.startsWith('/components/card')}>Card</SidebarItem>
          <SidebarItem href="/components/badge" active={path.startsWith('/components/badge')}>Badge</SidebarItem>
          <SidebarItem href="/components/alert" active={path.startsWith('/components/alert')}>Alert</SidebarItem>
        </SidebarSection>

        <SidebarSection label="Form">
          <SidebarItem href="/components/input" active={path.startsWith('/components/input')}>Input</SidebarItem>
          <SidebarItem href="/components/toggle" active={path.startsWith('/components/toggle')}>Toggle</SidebarItem>
          <SidebarItem href="/components/textarea" active={path.startsWith('/components/textarea')}>Textarea</SidebarItem>
        </SidebarSection>

        <SidebarSection label="Foundation">
          <SidebarItem href="/components/theme" active={path.startsWith('/components/theme')}>Theme</SidebarItem>
        </SidebarSection>

        <SidebarFooter>
          <div>
            <span class="text-[10px] font-semibold uppercase tracking-wider text-white/30 mb-1.5 block">Background</span>
            <BackgroundSwitcher client:load />
          </div>
          <div>
            <span class="text-[10px] font-semibold uppercase tracking-wider text-white/30 mb-1.5 block">Theme</span>
            <ThemeSwitcher client:load showMode={false} />
          </div>
        </SidebarFooter>
      </Sidebar>

      <!-- Main content -->
      <main class="flex-1 overflow-y-auto md:ml-64">
        <!-- Mobile header -->
        <header class="md:hidden flex items-center gap-3 p-4 border-b border-white/10">
          <a href="/" class="text-lg font-bold text-white flex items-center gap-2">
            <span class="w-7 h-7 rounded-lg bg-gradient-to-r from-cyan-500 via-blue-500 to-purple-500 flex items-center justify-center text-xs font-bold">G</span>
            GlassUI
          </a>
        </header>

        <div class="p-6 md:p-10 max-w-4xl">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
